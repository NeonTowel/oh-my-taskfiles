{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "azure-cognitive-services",
    "azure-moonshot",
    "google-vertex",
    "google-vertex-global",
    "azure-anthropic"
  ],
  "provider": {
    "azure-moonshot": {
      "name": "Microsoft Foundry (Moonshot)",
      "npm": "@ai-sdk/openai-compatible",
      "api": "https://{{ .Env.FOUNDRY_RESOURCE_NAME }}.services.ai.azure.com/models",
      "env": ["AZURE_OPENAI_API_KEY"],
      "models": {
        "kimi-k2.6": {
          "id": "kimi-k2.6",
          "name": "Kimi K2.6",
          "options": {
            "useCompletionUrls": true,
            "maxOutputTokens": 4096
          }
        }
      }
    },
    "azure-cognitive-services": {
      "options": {
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "resourceName": "{{ .Env.FOUNDRY_RESOURCE_NAME }}"
      },
      "models": {
        "gpt-5.3-codex": {
          "id": "gpt-5.3-codex",
          "name": "GPT-5.3 Codex"
        },
        "gpt-5.5": {
          "id": "gpt-5.5",
          "name": "GPT-5.5"
        },
        "gpt-5-mini": {
          "id": "gpt-5-mini",
          "name": "GPT-5 Mini"
        },
        "gpt-5.4-mini": {
            "id": "gpt-5.4-mini",
            "name": "GPT-5.4 Mini"
        },
        "gpt-5.4-nano": {
            "id": "gpt-5.4-nano",
            "name": "GPT-5.4 Nano"
        }
      }
    },
    "google-vertex-global": {
      "name": "Google Vertex (Global)",
      "npm": "@ai-sdk/google-vertex",
      "options": {
        "location": "global",
        "project": "{{ .Env.VERTEX_PROJECT_NAME }}"
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "id": "gemini-3.1-pro-preview",
          "name": "Gemini 3.1 Pro Preview",
          "options": {
            "thinkingConfig": {
              "includeThoughts": false,
              "thinkingLevel": "high"
            }
          }
        },
        "gemini-2.5-pro": {
          "id": "gemini-2.5-pro",
          "name": "Gemini 2.5 Pro",
          "options": {
            "thinkingConfig": {
              "includeThoughts": false
            }
          }
        },
        "gemini-2.5-flash": {
          "id": "gemini-2.5-flash",
          "name": "Gemini 2.5 Flash",
          "options": {
            "thinkingConfig": {
              "includeThoughts": false,
              "thinkingBudget": 8000
            }
          }
        },
        "gemini-2.5-flash-lite": {
          "id": "gemini-2.5-flash-lite",
          "name": "Gemini 2.5 Flash-Lite",
          "options": {
            "thinkingConfig": {
              "includeThoughts": false,
              "thinkingBudget": 0
            }
          }
        }
      }
    },
    "google-vertex": {
      "name": "Google Vertex ({{ .Env.VERTEX_LOCATION }})",
      "npm": "@ai-sdk/google-vertex",
      "options": {
        "location": "{{ .Env.VERTEX_LOCATION }}",
        "project": "{{ .Env.VERTEX_PROJECT_NAME }}"
      },
      "models": {
        "gemini-2.5-pro": {
          "id": "gemini-2.5-pro",
          "name": "Gemini 2.5 Pro",
          "options": {
            "thinkingConfig": {
              "includeThoughts": false
            }
          }
        },
        "gemini-2.5-flash": {
          "id": "gemini-2.5-flash",
          "name": "Gemini 2.5 Flash",
          "options": {
            "thinkingConfig": {
              "includeThoughts": false,
              "thinkingBudget": 8000
            }
          }
        },
        "gemini-2.5-flash-lite": {
          "id": "gemini-2.5-flash-lite",
          "options": {
            "thinkingConfig": {
              "includeThoughts": false,
              "thinkingBudget": 0
            }
          }
        }
      }
    },
    "azure-anthropic": {
      "name": "Microsoft Foundry (Anthropic)",
      "npm": "@ai-sdk/anthropic",
      "api": "https://{{ .Env.FOUNDRY_RESOURCE_NAME }}.services.ai.azure.com/anthropic/v1",
      "env": ["AZURE_OPENAI_API_KEY"],
      "models": {
        "claude-opus-4-7": {
          "id": "claude-opus-4-7",
          "name": "Claude Opus 4.7",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "cache_control": {
              "type": "ephemeral"
            },
            "thinking": {
              "type": "adaptive",
              "effort": "high"
            }
          }
        },
        "claude-opus-4-6": {
          "id": "claude-opus-4-6",
          "name": "Claude Opus 4.6",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "cache_control": {
              "type": "ephemeral"
            },
            "thinking": {
              "type": "adaptive",
              "effort": "high"
            }
          }
        },
        "claude-opus-4-5": {
          "id": "claude-opus-4-5",
          "name": "Claude Opus 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "cache_control": {
              "type": "ephemeral"
            },
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "claude-sonnet-4-6": {
          "id": "claude-sonnet-4-6",
          "name": "Claude Sonnet 4.6",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "thinking": {
              "type": "adaptive",
              "effort": "high"
            }
          }
        },
        "claude-sonnet-4-5": {
          "id": "claude-sonnet-4-5",
          "name": "Claude Sonnet 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "cache_control": {
              "type": "ephemeral"
            },
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "claude-haiku-4-5": {
          "id": "claude-haiku-4-5",
          "name": "Claude Haiku 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "cache_control": {
              "type": "ephemeral"
            },
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        }
      }
    }
  },
  "model": "azure-cognitive-services/gpt-5.3-codex",
  "small_model": "google-vertex/gemini-2.5-flash-lite",
  "default_agent": "coordinator",
  "autoupdate": true,
  "logLevel": "WARN",
  "share": "disabled",
  "formatter": true,
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow",
      "/tmp/**": "allow"
    },
    "bash": {
      "rm -fr /*": "deny",
      "rm -f /*": "deny",
      "rm -r /*": "deny",
    },
    "edit": {
      "README.md": "allow",
      "AGENTS.md": "allow",
      ".ai/plans/**": "allow",
      "~/.config/opencode/**": "deny",
      "*.env": "deny",
      ".env": "deny",
      ".*ignore": "deny"
    }
  },
  "compaction": {
      "prune": true,
      "auto": true
  },
  "mcp": {
    "context7": {
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.context7.com/mcp",
        "headers": {
            "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
        }
    },
    "Memory": {
        "type": "local",
        "command": ["bunx", "-y", "@modelcontextprotocol/server-memory"],
        "enabled": true
    },
    "Azure": {
        "type": "local",
        "command": ["bunx", "-y", "@azure/mcp@latest", "server", "start"],
        "enabled": false
    },
    "gh_grep": {
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.grep.app"
    },
    "exa": {
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.exa.ai/mcp"
    }
  },
  "agent": {
    "coordinator": {
      "description": "Workflow orchestrator managing specialized development agent teams",
      "prompt": "{file:./prompts/coordinator.md}",
      "mode": "all",
      "steps": 20,
      "model": "google-vertex/gemini-2.5-flash",
      "temperature": 0.1,
      "permission": {
        "*": "allow",
        "edit": "ask"
      }
    },
    "assistant": {
      "description": "Read-only investigative middleman for the coordinator",
      "prompt": "{file:./prompts/assistant.md}",
      "mode": "subagent",
      "steps": 40,
      "model": "google-vertex/gemini-2.5-flash",
      "temperature": 0.2,
      "permission": {
        "*": "allow",
        "edit": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git status*": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "find *": "allow",
          "rg *": "allow",
          "fd *": "allow",
          "wc *": "allow"
        }
      }
    },
    "architect": {
      "description": "Software architect designing modular, maintainable solutions",
      "prompt": "{file:./prompts/architect.md}",
      "mode": "all",
      "steps": 60,
      "model": "google-vertex-global/gemini-3.1-pro-preview",
      "temperature": 0.6,
      "permission": {
        "*": "allow"
      }
    },
    "architect-claude": {
      "description": "Software architect designing modular, maintainable solutions",
      "prompt": "{file:./prompts/architect.md}",
      "mode": "all",
      "steps": 60,
      "model": "azure-anthropic/claude-opus-4-7",
      "temperature": 0.6,
      "permission": {
        "*": "allow"
      }
    },
    "debug-agent": {
      "description": "Debug your application to find and fix a bug",
      "prompt": "{file:./prompts/debug-agent.md}",
      "mode": "all",
      "steps": 40,
      "model": "google-vertex/gemini-2.5-pro",
      "temperature": 0.2,
      "permission": {
        "*": "allow"
      }
    },
    "developer": {
      "description": "Software engineer implementing features following architectural specifications",
      "prompt": "{file:./prompts/developer.md}",
      "mode": "all",
      "steps": 60,
      "model": "azure-cognitive-services/gpt-5.3-codex",
      "temperature": 0.4,
      "permission": {
        "*": "allow"
      }
    },
    "senior-developer": {
      "description": "Senior software engineer implementing high quality features following architectural specifications",
      "prompt": "{file:./prompts/senior-developer.md}",
      "mode": "all",
      "steps": 60,
      "model": "google-vertex-global/gemini-3.1-pro-preview",
      "temperature": 0.4,
      "permission": {
        "*": "allow"
      }
    },
    "senior-developer-claude": {
      "description": "Senior software engineer implementing high quality features following architectural specifications",
      "prompt": "{file:./prompts/senior-developer.md}",
      "mode": "all",
      "steps": 60,
      "model": "azure-anthropic/claude-sonnet-4-6",
      "temperature": 0.4,
      "permission": {
        "*": "allow"
      }
    },
    "planner": {
      "description": "Generate an implementation plan for new features or refactoring existing code",
      "prompt": "{file:./prompts/planner.md}",
      "mode": "all",
      "steps": 40,
      "model": "google-vertex/gemini-2.5-pro",
      "temperature": 0.3,
      "permission": {
        "*": "allow"
      }
    },
    "devops-architect": {
      "description": "SRE-focused Kubernetes specialist prioritizing reliability, safe rollouts/rollbacks, security defaults, and operational verification for production-grade deployments",
      "prompt": "{file:./prompts/devops-architect.md}",
      "mode": "all",
      "steps": 40,
      "model": "google-vertex/gemini-2.5-pro",
      "temperature": 0.6,
      "permission": {
        "*": "allow"
      }
    },
    "sre": {
      "description": "SRE-focused Kubernetes specialist prioritizing reliability, safe rollouts/rollbacks, security defaults, and operational verification for production-grade deployments",
      "prompt": "{file:./prompts/sre.md}",
      "mode": "all",
      "steps": 20,
      "model": "google-vertex/gemini-2.5-pro",
      "temperature": 0.3,
      "permission": {
        "*": "allow"
      }
    },
    "refactor": {
      "description": "Refactoring specialist improving code quality while preserving functionality",
      "prompt": "{file:./prompts/refactor.md}",
      "mode": "subagent",
      "steps": 40,
      "model": "azure-moonshot/kimi-k2.6",
      "options": {
        "thinking": {
          "type": "enabled"
        },
        "maxTokens": 30000
      },
      "permission": {
        "*": "allow"
      }
    },
    "reviewer": {
      "description": "Refactoring specialist improving code quality while preserving functionality",
      "prompt": "{file:./prompts/refactor.md}",
      "mode": "subagent",
      "steps": 20,
      "model": "azure-moonshot/kimi-k2.6",
      "options": {
        "thinking": {
          "type": "disabled"
        },
        "maxTokens": 5000
      },
      "permission": {
        "*": "allow"
      }
    },
    "tester": {
      "description": "Test engineer validating code correctness and coverage",
      "prompt": "{file:./prompts/tester.md}",
      "mode": "all",
      "steps": 40,
      "model": "azure-moonshot/kimi-k2.6",
      "options": {
        "thinking": {
          "type": "enabled"
        },
        "maxTokens": 10000
      },
      "permission": {
        "*": "allow"
      }
    }
  }
}
