{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "azure-cognitive-services",
    "azure-moonshot",
    "google-vertex",
    "google-vertex-global",
    "azure-anthropic"
  ],
  "provider": {
    "azure-moonshot": {
      "name": "Microsoft Foundry (Moonshot)",
      "npm": "@ai-sdk/openai-compatible",
      "api": "https://{{ .Env.FOUNDRY_RESOURCE_NAME }}.services.ai.azure.com/models",
      "env": ["AZURE_OPENAI_API_KEY"],
      "models": {
        "kimi-k2-thinking": {
          "id": "kimi-k2-thinking",
          "name": "Kimi K2 Thinking",
          "options": {
            "useCompletionUrls": true
          }
        }
      }
    },
    "azure-cognitive-services": {
      "options": {
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "resourceName": "{{ .Env.FOUNDRY_RESOURCE_NAME }}"
      },
      "models": {
        "gpt-5-mini": {
          "id": "gpt-5-mini",
          "name": "GPT-5 Mini"
        },
        "gpt-5.4-mini": {
            "id": "gpt-5.4-mini",
            "name": "GPT-5.4 Mini"
        },
        "gpt-5.4-nano": {
            "id": "gpt-5.4-nano",
            "name": "GPT-5.4 Nano"
        }
      }
    },
    "google-vertex-global": {
      "name": "Google Vertex (Global)",
      "npm": "@ai-sdk/google-vertex",
      "options": {
        "location": "global",
        "project": "{{ .Env.VERTEX_PROJECT_NAME }}"
      },
      "models": {
        "gemini-3.1-pro-preview": {
            "id": "gemini-3.1-pro-preview",
            "name": "Gemini 3.1 Pro Preview"
        },
        "gemini-2.5-pro": {
            "id": "gemini-2.5-pro",
            "name": "Gemini 2.5 Pro"
        },
        "gemini-2.5-flash": {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash"
        },
        "gemini-2.5-flash-lite": {
            "id": "gemini-2.5-flash-lite",
            "name": "Gemini 2.5 Flash-Lite",
            "options": {
                "thinkingConfig": {
                    "includeThoughts": false,
                    "thinkingBudget": 0
                }
            }
        }
      }
    },
    "google-vertex": {
      "name": "Google Vertex ({{ .Env.VERTEX_LOCATION }})",
      "npm": "@ai-sdk/google-vertex",
      "options": {
        "location": "{{ .Env.VERTEX_LOCATION }}",
        "project": "{{ .Env.VERTEX_PROJECT_NAME }}"
      },
      "models": {
        "gemini-2.5-pro": {
            "id": "gemini-2.5-pro",
            "name": "Gemini 2.5 Pro"
        },
        "gemini-2.5-flash": {
          "id": "gemini-2.5-flash",
          "name": "Gemini 2.5 Flash"
        },
        "gemini-2.5-flash-lite": {
            "id": "gemini-2.5-flash-lite",
            "options": {
                "thinkingConfig": {
                    "includeThoughts": false,
                    "thinkingBudget": 0
                }
            }
        }
      }
    },
    "azure-anthropic": {
      "name": "Microsoft Foundry (Anthropic)",
      "npm": "@ai-sdk/anthropic",
      "api": "https://{{ .Env.FOUNDRY_RESOURCE_NAME }}.services.ai.azure.com/anthropic/v1",
      "env": ["AZURE_OPENAI_API_KEY"],
      "models": {
        "claude-opus-4-6": {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "tool_call": true,
            "attachment": true,
            "reasoning": true,
            "temperature": true,
            "options": {
                "thinking": {
                    "type": "enabled",
                    "budgetTokens": 16000
                }
            }
        },
        "claude-opus-4-5": {
          "id": "claude-opus-4-5",
          "name": "Claude Opus 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "claude-sonnet-4-6": {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "tool_call": true,
            "attachment": true,
            "reasoning": true,
            "temperature": true,
            "options": {
                "thinking": {
                    "type": "enabled",
                    "budgetTokens": 16000
                }
            }
        },
        "claude-sonnet-4-5": {
          "id": "claude-sonnet-4-5",
          "name": "Claude Sonnet 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "claude-haiku-4-5": {
          "id": "claude-haiku-4-5",
          "name": "Claude Haiku 4.5",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        }
      }
    }
  },
  "default_agent": "coordinator",
  "model": "azure-cognitive-services/gpt-5.4-mini",
  "small_model": "azure-cognitive-services/gpt-5.4-nano",
  "autoupdate": "notify",
  "logLevel": "WARN",
  "share": "disabled",
    "permission": {
        "external_directory": {
            "~/.config/opencode/**": "allow",
            "/tmp/**": "allow"
        },
        "edit": {
            "README.md": "allow",
            "AGENTS.md": "allow",
            ".ai/plans/**": "allow",
            "~/.config/opencode/**": "deny"
        }
    },
    "compaction": {
        "prune": true,
        "auto": true
    },
    "mcp": {
      "context7": {
          "enabled": true,
          "type": "remote",
          "url": "https://mcp.context7.com/mcp",
          "headers": {
              "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
          }
      },
      "Memory": {
          "type": "local",
          "command": ["bunx", "-y", "@modelcontextprotocol/server-memory"],
          "enabled": true
      },
      "Azure": {
          "type": "local",
          "command": ["bunx", "-y", "@azure/mcp@latest", "server", "start"],
          "enabled": true
      },
      "gh_grep": {
          "enabled": true,
          "type": "remote",
          "url": "https://mcp.grep.app"
      },
      "exa": {
          "enabled": true,
          "type": "remote",
          "url": "https://mcp.exa.ai/mcp"
      }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "tools": {
        "exa_*": true,
        "gh_grep_*": true,
        "context7_*": true,
        "bash": true,
        "edit": true,
        "write": true,
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "patch": true,
        "skill": true,
        "todowrite": true,
        "todoread": true,
        "webfetch": true
      }
    },
    "plan": {
      "mode": "primary",
      "tools": {
        "exa_*": true,
        "gh_grep_*": true,
        "context7_*": true,
        "bash": true,
        "edit": true,
        "write": true,
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "patch": true,
        "skill": true,
        "todowrite": true,
        "todoread": true,
        "webfetch": true
      }
    }
  }
}
