{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "coordinator",
    "model": "azure-cognitive-services/gpt-5.4-mini",
    "small_model": "azure-cognitive-services/gpt-5.4-nano",
    "autoupdate": "notify",
    "logLevel": "WARN",
    "share": "disabled",
    "permission": {
        "external_directory": {
            "~/.config/opencode/**": "allow",
            "/tmp/**": "allow"
        },
        "edit": {
            "README.md": "allow",
            "AGENTS.md": "allow",
            ".ai/plans/**": "allow",
            "~/.config/opencode/**": "deny"
        }
    },
    "compaction": {
        "prune": true,
        "auto": true
    },
    "mcp": {
        "context7": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            }
        },
        "Memory": {
            "type": "local",
            "command": ["bunx", "-y", "@modelcontextprotocol/server-memory"],
            "enabled": true
        },
        "Azure": {
            "type": "local",
            "command": ["bunx", "-y", "@azure/mcp@latest", "server", "start"],
            "enabled": true
        },
        "gh_grep": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.grep.app"
        },
        "exa": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp"
        }
    },
    "agent": {
        "build": {
            "mode": "primary",
            "temperature": 0.3,
            "tools": {
                "bash": true,
                "edit": true,
                "write": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "patch": true,
                "skill": true,
                "todowrite": true,
                "todoread": true,
                "webfetch": true
            }
        },
        "plan": {
            "mode": "primary",
            "temperature": 0.6,
            "tools": {
                "bash": true,
                "edit": true,
                "write": true,
                "read": true,
                "grep": true,
                "glob": true,
                "list": true,
                "patch": true,
                "skill": true,
                "todowrite": true,
                "todoread": true,
                "webfetch": true
            }
        }
    }
}
