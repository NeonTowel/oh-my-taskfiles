{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "openai",
    "google",
    "anthropic",
    "moonshotai"
  ],
  "model": "openai/gpt-5.3-codex",
  "small_model": "google/gemini-2.5-flash-lite",
  "default_agent": "coordinator",
  "autoupdate": true,
  "logLevel": "WARN",
  "share": "disabled",
  "formatter": true,
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow",
      "/tmp/**": "allow"
    },
    "bash": {
      "rm -fr /*": "deny",
      "rm -f /*": "deny",
      "rm -r /*": "deny",
    },
    "edit": {
      "README.md": "allow",
      "AGENTS.md": "allow",
      ".ai/plans/**": "allow",
      "~/.config/opencode/**": "deny",
      "*.env": "deny",
      ".env": "deny",
      ".*ignore": "deny"
    }
  },
  "compaction": {
      "prune": true,
      "auto": true
  },
  "mcp": {
    "context7": {
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.context7.com/mcp",
        "headers": {
            "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
        }
    },
    "Memory": {
        "type": "local",
        "command": ["bunx", "-y", "@modelcontextprotocol/server-memory"],
        "enabled": true
    },
    "Azure": {
        "type": "local",
        "command": ["bunx", "-y", "@azure/mcp@latest", "server", "start"],
        "enabled": false
    },
    "gh_grep": {
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.grep.app"
    },
    "exa": {
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.exa.ai/mcp"
    }
  },
  "agent": {
    "coordinator": {
      "description": "Workflow orchestrator managing specialized development agent teams",
      "prompt": "{file:./prompts/coordinator.md}",
      "mode": "all",
      "steps": 80,
      "model": "google-vertex/gemini-2.5-flash",
      "temperature": 0.1,
      "permission": {
        "*": "allow",
        "edit": "ask"
      }
    },
    "assistant": {
      "description": "Read-only investigative middleman for the coordinator",
      "prompt": "{file:./prompts/assistant.md}",
      "mode": "subagent",
      "steps": 60,
      "model": "google-vertex/gemini-2.5-flash",
      "temperature": 0.2,
      "permission": {
        "*": "allow",
        "edit": "deny",
        "todowrite": "deny",
        "task": "deny",
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git status*": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "find *": "allow",
          "rg *": "allow",
          "fd *": "allow",
          "wc *": "allow"
        }
      }
    },
    "architect": {
      "description": "Software architect designing modular, maintainable solutions",
      "prompt": "{file:./prompts/architect.md}",
      "mode": "all",
      "steps": 120,
      "model": "google/gemini-3.1-pro-preview",
      "temperature": 0.6,
      "permission": {
        "*": "allow"
      }
    },
    "architect-claude": {
      "description": "Software architect designing modular, maintainable solutions",
      "prompt": "{file:./prompts/architect.md}",
      "mode": "all",
      "steps": 120,
      "model": "anthropic/claude-opus-4-7",
      "temperature": 0.6,
      "permission": {
        "*": "allow"
      }
    },
    "debug-agent": {
      "description": "Debug your application to find and fix a bug",
      "prompt": "{file:./prompts/debug-agent.md}",
      "mode": "all",
      "steps": 60,
      "model": "google/gemini-2.5-pro",
      "temperature": 0.2,
      "permission": {
        "*": "allow"
      }
    },
    "developer": {
      "description": "Software engineer implementing features following architectural specifications",
      "prompt": "{file:./prompts/developer.md}",
      "mode": "all",
      "steps": 120,
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.4,
      "permission": {
        "*": "allow"
      }
    },
    "senior-developer": {
      "description": "Senior software engineer implementing high quality features following architectural specifications",
      "prompt": "{file:./prompts/senior-developer.md}",
      "mode": "all",
      "steps": 120,
      "model": "google/gemini-3.1-pro-preview",
      "temperature": 0.4,
      "permission": {
        "*": "allow"
      }
    },
    "senior-developer-claude": {
      "description": "Senior software engineer implementing high quality features following architectural specifications",
      "prompt": "{file:./prompts/senior-developer.md}",
      "mode": "all",
      "steps": 120,
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.4,
      "permission": {
        "*": "allow"
      }
    },
    "planner": {
      "description": "Generate an implementation plan for new features or refactoring existing code",
      "prompt": "{file:./prompts/planner.md}",
      "mode": "all",
      "steps": 60,
      "model": "google/gemini-2.5-pro",
      "temperature": 0.3,
      "permission": {
        "*": "allow"
      }
    },
    "devops-architect": {
      "description": "SRE-focused Kubernetes specialist prioritizing reliability, safe rollouts/rollbacks, security defaults, and operational verification for production-grade deployments",
      "prompt": "{file:./prompts/devops-architect.md}",
      "mode": "all",
      "steps": 60,
      "model": "google-vertex/gemini-2.5-pro",
      "temperature": 0.6,
      "permission": {
        "*": "allow"
      }
    },
    "sre": {
      "description": "SRE-focused Kubernetes specialist prioritizing reliability, safe rollouts/rollbacks, security defaults, and operational verification for production-grade deployments",
      "prompt": "{file:./prompts/sre.md}",
      "mode": "all",
      "steps": 60,
      "model": "google/gemini-2.5-pro",
      "temperature": 0.3,
      "permission": {
        "*": "allow"
      }
    },
    "refactor": {
      "description": "Refactoring specialist improving code quality while preserving functionality",
      "prompt": "{file:./prompts/refactor.md}",
      "mode": "subagent",
      "steps": 80,
      "model": "moonshotai/kimi-k2.6",
      "options": {
        "thinking": {
          "type": "enabled"
        },
        "maxTokens": 30000
      },
      "permission": {
        "*": "allow"
      }
    },
    "reviewer": {
      "description": "Refactoring specialist improving code quality while preserving functionality",
      "prompt": "{file:./prompts/refactor.md}",
      "mode": "subagent",
      "steps": 80,
      "model": "moonshotai/kimi-k2.6",
      "options": {
        "thinking": {
          "type": "disabled"
        },
        "maxTokens": 5000
      },
      "permission": {
        "*": "allow"
      }
    },
    "tester": {
      "description": "Test engineer validating code correctness and coverage",
      "prompt": "{file:./prompts/tester.md}",
      "mode": "all",
      "steps": 80,
      "model": "moonshotai/kimi-k2.6",
      "options": {
        "thinking": {
          "type": "enabled"
        },
        "maxTokens": 10000
      },
      "permission": {
        "*": "allow"
      }
    }
  }
}
